{
  "name": "upload-server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch --env-file .env src/infra/http/server.ts",
    "test": "dotenv -e .env.test -- bun test",
    "test:watch": "dotenv -e .env.test -- bun test --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:test": "dotenv -e .env.test -- drizzle-kit migrate",
    "pretest": "bun run db:migrate:test",
    "pretest:watch": "bun run db:migrate:test",
    "build": "tsup-node",
    "start": "bun dist/infra/http/server.js"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1019.0",
    "@aws-sdk/lib-storage": "3.1019.0",
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/swagger": "9.6.1",
    "@fastify/swagger-ui": "5.2.4",
    "csv-stringify": "6.6.0",
    "dayjs": "1.11.19",
    "drizzle-orm": "0.45.1",
    "fastify": "5.8.1",
    "fastify-type-provider-zod": "6.1.0",
    "postgres": "3.4.8",
    "uuidv7": "1.1.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@faker-js/faker": "10.2.0",
    "@types/bun": "latest",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.8",
    "tsup": "8.5.1",
    "tsx": "4.21.0"
  }
}
